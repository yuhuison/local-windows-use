{
  "name": "windows-use",
  "version": "0.1.0",
  "description": "Let big LLMs delegate Windows/browser automation to small LLMs via sessions",
  "type": "module",
  "bin": {
    "windows-use": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./mcp": {
      "import": "./dist/mcp/server.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@nut-tree-fork/nut-js": "^4.2.6",
    "commander": "^13.1.0",
    "node-screenshots": "^0.2.8",
    "openai": "^4.86.0",
    "playwright": "^1.50.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "windows",
    "automation",
    "mcp",
    "llm",
    "agent",
    "browser"
  ],
  "license": "MIT"
}
